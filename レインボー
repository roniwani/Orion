-- 🎯 TARGET EXECUTION
UI:AddSection("🎯 TARGET EXECUTION")

local selectedTargetPlayer = nil
local loopKickActive = false
local loopKickConnection = nil

local function getPlayerNames()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Player then
            table.insert(list, p.DisplayName .. " (" .. p.Name .. ")")
        end
    end
    return list
end

local function getPlayerFromFormat(val)
    if not val then return nil end
    local uName = val:match("%((.-)%)")
    return uName and Players:FindFirstChild(uName) or nil
end

local TargetDropdown
TargetDropdown = UI:AddDropdown("Select Bad Player", getPlayerNames(), function(Value)
    selectedTargetPlayer = getPlayerFromFormat(Value)
end)

UI:AddButton("🔄 Refresh Player List", function()
    TargetDropdown:Refresh(getPlayerNames(), true)
    selectedTargetPlayer = nil
end)

UI:AddToggle("⚡ Loop Kick (Network Owner Spam)", function(Value)
    loopKickActive = Value
    if Value then
        if not selectedTargetPlayer then return end
        if loopKickConnection then loopKickConnection:Disconnect() end
        loopKickConnection = RunService.Heartbeat:Connect(function()
            if not loopKickActive or not selectedTargetPlayer then 
                if loopKickConnection then loopKickConnection:Disconnect() loopKickConnection = nil end
                return 
            end
            
            pcall(function()
                local tChar = selectedTargetPlayer.Character
                local tHrp = tChar and tChar:FindFirstChild("HumanoidRootPart")
                local myHrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                
                if tHrp and myHrp then
                    ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(tHrp, myHrp.CFrame)
                    tHrp.CFrame = tHrp.CFrame + Vector3.new(0, 80, 0)
                end
            end)
        end)
    else
        if loopKickConnection then loopKickConnection:Disconnect() loopKickConnection = nil end
    end
end)

